DATABASE_URL=postgres://postgres:root@127.0.0.1:5432/prismapply?sslmode=disable

OPENAI_API_KEY=
MODEL=openai/gpt-4o-mini

CHROME_PATH=/usr/bin/google-chrome-stable

R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=prismapply
R2_PUBLIC_URL=

# Stagehand / Browserbase (scrape + form enrichment)
ENV=LOCAL
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

REDIS_ADDR=127.0.0.1:6379
# Leave empty when local Redis has no requirepass (same as api/.env). Or set REDIS_URL=redis://:pass@host:6379/0
REDIS_PASSWORD=

TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TASK_QUEUE=prismapply-orchestration

# Serper.dev Google Search API (job discovery — https://serper.dev)
SERPER_API_KEY=

# Job discovery tuning (optional)
DISCOVERY_ENABLED=true
DISCOVERY_CRON_SCHEDULE=0 */6 * * *
DISCOVERY_MAX_SCRAPES_PER_RUN=50
DISCOVERY_SERPER_NUM_RESULTS=10
DISCOVERY_SEARCH_FRESHNESS_DAYS=30

# Matching v2 (Layer 3 LLM adjudicator; set false to skip)
# MATCH_ADJUDICATION_ENABLED=true
# MATCH_ADJUDICATION_MODEL=gpt-4o-mini
