# Public URLs (baked into build — set in Railway / Cloudflare env vars)
PUBLIC_SITE_URL=https://prismapply.com
PUBLIC_APP_URL=https://app.prismapply.com

# PostHog (optional — leave unset to disable analytics)
# Project API key from PostHog → Project Settings → Project API key
PUBLIC_POSTHOG_KEY=phc_your_project_api_key
# EU cloud: https://eu.i.posthog.com  |  US cloud: https://us.i.posthog.com
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Local dev
# PUBLIC_APP_URL=http://localhost:5173
# PUBLIC_POSTHOG_KEY=
