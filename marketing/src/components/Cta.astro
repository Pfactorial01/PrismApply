---
import SignupLink from './SignupLink.astro'
import { site } from '../config'
---

<section class="border-t border-border bg-muted/30 py-16 sm:py-20">
  <div class="site-container text-center">
    <h2 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
      Ready to put your best foot forward?
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-muted-foreground xl:max-w-2xl">
      {site.describeOnce}
    </p>
    <SignupLink
      location="home-cta"
      class="mt-8 inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-base font-medium text-primary-foreground shadow-sm transition-opacity hover:opacity-90"
    >
      Get started — it's free
    </SignupLink>
  </div>
</section>
