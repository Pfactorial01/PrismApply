---
import { site } from '../config'
const year = new Date().getFullYear()
---

<footer class="mt-auto border-t border-border bg-muted/40">
  <div class="site-container flex flex-col gap-6 py-10 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="font-semibold text-foreground">{site.name}</p>
      <p class="mt-1 max-w-sm text-sm text-muted-foreground">{site.tagline}</p>
    </div>
    <p class="text-sm text-muted-foreground">© {year} {site.name}. All rights reserved.</p>
  </div>
</footer>
