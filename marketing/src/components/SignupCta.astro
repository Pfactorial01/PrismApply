---
import SignupLink from './SignupLink.astro'
import { site } from '../config'

interface Props {
  heading?: string
  body?: string
  location?: string
}

const {
  heading = 'Ready to put your best foot forward?',
  body = site.describeOnce,
  location = 'page-cta',
} = Astro.props
---

<section class="border-t border-border bg-muted/30 py-14 sm:py-16">
  <div class="site-container text-center">
    <h2 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">{heading}</h2>
    <p class="mx-auto mt-4 max-w-xl text-muted-foreground">{body}</p>
    <SignupLink
      location={location}
      class="mt-8 inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-base font-medium text-primary-foreground shadow-sm transition-opacity hover:opacity-90"
    >
      Build your profile once — free
    </SignupLink>
  </div>
</section>
