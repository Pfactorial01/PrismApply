---
import { site } from '../config'
---

<section class="border-b border-border bg-muted/20 py-16 sm:py-20">
  <div class="site-container">
    <div class="mx-auto max-w-3xl text-center xl:max-w-4xl 2xl:max-w-5xl">
    <h2 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
      The old way does not work
    </h2>
    <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
      {site.problem}
    </p>
    <p class="mt-4 text-base leading-relaxed text-muted-foreground">
      PrismApply puts your best foot forward for every role — without asking you to rewrite the same story dozens of times.
    </p>
    </div>
  </div>
</section>
