---
import '../styles/global.css'
import { site } from '../config'
import Analytics from '../components/Analytics.astro'
import JsonLd from '../components/JsonLd.astro'
import { canonicalUrl, defaultOgImage, organizationJsonLd, softwareApplicationJsonLd } from '../lib/seo'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  includeSoftwareAppSchema?: boolean
  noindex?: boolean
}

const {
  title,
  description = site.description,
  ogImage = defaultOgImage,
  jsonLd,
  includeSoftwareAppSchema = false,
  noindex = false,
} = Astro.props

const pageTitle = title ? `${title} · ${site.name}` : site.name
const canonical = canonicalUrl(Astro.url.pathname)
const ogImageUrl = ogImage.startsWith('http') ? ogImage : canonicalUrl(ogImage)

const schemas: Record<string, unknown>[] = [organizationJsonLd()]
if (includeSoftwareAppSchema) schemas.push(softwareApplicationJsonLd())
if (jsonLd) {
  if (Array.isArray(jsonLd)) schemas.push(...jsonLd)
  else schemas.push(jsonLd)
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : null}

    <title>{pageTitle}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#C45A22" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} — ${site.tagline}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`${site.name} — ${site.tagline}`} />

    <JsonLd data={schemas} />
    <Analytics />
  </head>
  <body class="min-h-dvh flex flex-col">
    <slot />
  </body>
</html>
