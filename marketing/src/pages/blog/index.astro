---
import { getCollection } from 'astro:content'
import PageLayout from '../../layouts/PageLayout.astro'
import PageHero from '../../components/PageHero.astro'

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)
---

<PageLayout
  title="Blog"
  description="Job search strategy, honest AI tailoring, and tech hiring insights from the PrismApply team."
>
  <PageHero
    eyebrow="Blog"
    title="Job search strategy for serious applicants"
    description="Problem-first guides on tailoring, honest AI, ATS platforms, and software engineer job search — not feature posts."
    align="center"
  />

  <section class="site-container pb-16">
    <ul class="grid gap-6 sm:grid-cols-2">
      {posts.map((post) => (
        <li class="rounded-xl border border-border bg-card p-6 transition-colors hover:border-primary/30">
          <time datetime={post.data.pubDate.toISOString()} class="text-xs font-medium uppercase tracking-wide text-primary">
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <h2 class="mt-2 text-xl font-semibold text-foreground">
            <a href={`/blog/${post.slug}`} class="hover:text-primary">{post.data.title}</a>
          </h2>
          <p class="mt-2 text-sm text-muted-foreground leading-relaxed">{post.data.description}</p>
          <a href={`/blog/${post.slug}`} class="mt-4 inline-block text-sm font-medium text-primary hover:underline">
            Read article →
          </a>
        </li>
      ))}
    </ul>
  </section>
</PageLayout>
