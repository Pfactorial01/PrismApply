# syntax=docker/dockerfile:1
# Long-running Redis consumer: profile embeddings (no Chrome).

FROM golang:1.22-bookworm AS builder
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/prismapply-embed-worker ./cmd/worker

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /out/prismapply-embed-worker /prismapply-embed-worker
USER nonroot:nonroot
ENTRYPOINT ["/prismapply-embed-worker"]
