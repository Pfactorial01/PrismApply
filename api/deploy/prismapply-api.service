[Unit]
Description=PrismApply HTTP API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Create a dedicated account first, e.g. useradd --system --home /nonexistent --shell /usr/sbin/nologin prismapply
User=prismapply
Group=prismapply
EnvironmentFile=-/etc/prismapply/api.env
ExecStart=/usr/local/bin/prismapply-api
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
