# PostgreSQL (required). Create DB first, e.g. CREATE DATABASE prismapply;
DATABASE_URL=postgres://USER:PASS@127.0.0.1:5432/prismapply?sslmode=disable

# HTTP
PORT=9001

# JWT signing (set a long random string in production)
JWT_SECRET=change-me

# Token lifetimes (optional)
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=14

# Redis (defaults shown)
REDIS_ADDR=127.0.0.1:6379
# Required when Redis has requirepass (otherwise API/worker get NOAUTH)
REDIS_PASSWORD=
# Optional: overrides REDIS_ADDR / REDIS_PASSWORD / REDIS_DB (password after second colon)
# REDIS_URL=redis://:your_password@127.0.0.1:6379/0
# REDIS_DB=0
#
# Shell note: if you `export REDIS_ADDR=...` and then `set -a && . ./.env`, lines in `.env` replace
# your exports. Load `.env` first, then `export` overrides, or use `make run-dev-redis` with a dev
# Redis on REDIS_ADDR_DEV (default 127.0.0.1:16379).

# Cookies (optional; leave COOKIE_DOMAIN empty for localhost)
# Railway pattern A (nginx gateway): leave COOKIE_DOMAIN empty — app host serves /api too.
# Railway pattern B (separate api.* domain): COOKIE_DOMAIN=.prismapply.com
# COOKIE_SECURE=true
# COOKIE_DOMAIN=

# Profile embedding worker (cmd/worker): OpenAI-compatible embeddings API
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_QUEUE_KEY=prismapply:embed:profile
# EMBEDDING_DLQ_KEY=prismapply:embed:profile:dlq
#
# Layer 3 match adjudication (reverse + forward; set false to skip LLM gate)
# MATCH_ADJUDICATION_ENABLED=true
# MATCH_ADJUDICATION_MODEL=gpt-4o-mini
#
# Background job queues (cmd/jobworker)
# MATCH_QUEUE_KEY=prismapply:match:new
# JOB_PROCESS_QUEUE_KEY=prismapply:job:process
# JOBS_DLQ_KEY=prismapply:jobs:dlq
#
# Tailoring LLM + PDF (cmd/jobworker)
# TAILOR_MODEL=gpt-4o-mini
# CHROME_PATH=/usr/bin/google-chrome-stable
# Railway Docker images use: CHROME_PATH=/usr/bin/chromium
#
# Cloudflare R2 (resume PDF upload)
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=
#
# Job discovery (cmd/discover — run via cron/systemd timer)
# DISCOVERY_ENABLED=true
# SERPER_API_KEY=
# DISCOVERY_INTERVAL_HOURS=6
# DISCOVERY_MAX_SCRAPES_PER_RUN=50
# DISCOVERY_SERPER_NUM_RESULTS=10
# DISCOVERY_SEARCH_FRESHNESS_DAYS=30
#
# Jobs / tailoring (discovered_jobs, job_matches, tailored_applications):
# jobs UNIQUE (user_id, url_sha256); tailor_jobs UNIQUE (user_id, job_id) + (user_id, idempotency_key)
