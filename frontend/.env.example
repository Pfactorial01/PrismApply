# PostHog — same project key as marketing for cross-domain funnel
VITE_POSTHOG_KEY=phc_your_project_api_key
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Optional override (defaults to .prismapply.com in prod)
# VITE_POSTHOG_COOKIE_DOMAIN=.prismapply.com

# API base URL — leave unset when using same-origin /api via nginx gateway
# VITE_API_BASE_URL=https://api.prismapply.com
