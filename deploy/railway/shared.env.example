# Shared secrets for api, embed-worker, jobworker, discover (Railway variable group).
# Reference managed services with Railway's ${{Service.VAR}} syntax in the dashboard.

# --- Managed (Railway plugins) ---
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# REDIS_URL=${{Redis.REDIS_URL}}

# --- HTTP / auth (gateway same-origin setup) ---
# PORT=8080
# JWT_SECRET=
# COOKIE_SECURE=true
# Leave COOKIE_DOMAIN empty when using deploy/nginx gateway (app host serves /api too).
# COOKIE_DOMAIN=
# ADMIN_EMAILS=you@example.com

# --- OpenAI ---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# TAILOR_MODEL=gpt-4o-mini
# MATCH_ADJUDICATION_ENABLED=true

# --- Cloudflare R2 ---
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# --- Chrome workers (jobworker + discover images) ---
# CHROME_PATH=/usr/bin/chromium

# --- Discovery ---
# DISCOVERY_ENABLED=true
# SERPER_API_KEY=
# DISCOVERY_MAX_SCRAPES_PER_RUN=50

# --- Gateway (deploy/nginx service only) ---
# APP_HOST=app.prismapply.com
# MARKETING_HOST=prismapply.com
# API_HOST=${{api.RAILWAY_PRIVATE_DOMAIN}}
# API_PORT=${{api.PORT}}
# FRONTEND_HOST=${{frontend.RAILWAY_PRIVATE_DOMAIN}}
# FRONTEND_PORT=${{frontend.PORT}}
# MARKETING_UPSTREAM_HOST=${{marketing.RAILWAY_PRIVATE_DOMAIN}}
# MARKETING_UPSTREAM_PORT=${{marketing.PORT}}

# --- Frontend build (frontend service; leave empty with gateway) ---
# VITE_API_BASE_URL=

# --- Marketing build (marketing service) ---
# PUBLIC_SITE_URL=https://prismapply.com
# PUBLIC_APP_URL=https://app.prismapply.com
